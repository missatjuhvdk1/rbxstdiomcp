# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
*.tsbuildinfo

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Development files (keep local only)
CLAUDE.md
# Exception: studio-plugin/ ships its own committed agent pointer alongside
# ARCHITECTURE.md (REFACTOR_PLAN.md Phase 1 deliverable; pre-cutover this
# lived at MCPPlugin/CLAUDE.md).
!studio-plugin/CLAUDE.md
MCP_Server_Plan.md
test-*.js
example-*.json
mcp.json

# OS files
.DS_Store
Thumbs.db
*:Zone.Identifier

# Logs
logs/
*.log

.WARP.md

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# Temporary folders
tmp/
temp/

# AI-generated content
banner-prompt.txt
forum-title.txt

# Local reference docs (sparse-cloned creator-docs for development)
.refdocs/

# npm credentials
.npmrc

# Studio plugin build outputs / restored deps (REFACTOR_PLAN Phase 7).
# studio-plugin/.gitignore has its own copy; we mirror at root so anyone
# running git from the project root never accidentally commits build output.
studio-plugin/Packages/
studio-plugin/*.rbxm
studio-plugin/*.rbxmx
studio-plugin/sourcemap.json
studio-plugin/.lune/
